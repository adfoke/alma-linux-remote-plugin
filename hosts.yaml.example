hosts:
  my-server:
    host: 192.168.1.100
    username: root
    auth:
      method: password
      password_env: MY_SERVER_PASS
  dev-box:
    host: dev.example.com
    username: ubuntu
    auth:
      method: key
      key_path: ~/.ssh/id_ed25519

session:
  idle_timeout_seconds: 300

audit:
  enabled: true
  db_path: ./logs/audit.db
  dashboard_host: 127.0.0.1
  dashboard_port: 8765